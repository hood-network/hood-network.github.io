{
	"name": "hnfront",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"lint": "biome lint --max-diagnostics=none",
		"lint:fix": "biome lint --max-diagnostics=none --write",
		"format": "prettier --check src/**/*.astro && biome check --max-diagnostics=none --linter-enabled=false",
		"format:fix": "prettier --write src/**/*.astro && biome check --max-diagnostics=none --linter-enabled=false --write",
		"prebuild": "node ./guest-authors.ts",
		"dev": "pnpm run prebuild && astro dev",
		"build": "pnpm run prebuild && astro build",
		"preview": "pnpm run prebuild && astro preview"
	},
	"packageManager": "pnpm@10.11.1",
	"dependencies": {
		"astro": "7.0.2",
		"sass": "^1.101.0"
	},
	"devDependencies": {
		"@astrojs/markdown-remark": "7.2.0",
		"@biomejs/biome": "2.5.1",
		"@richardtowers/remark-abbr": "1.1.5",
		"@syntect/node": "0.0.4",
		"@types/mdast": "4.0.4",
		"@types/node": "26.0.1",
		"github-slugger": "2.0.0",
		"mdast-util-to-string": "4.0.0",
		"murmurhash": "2.0.1",
		"prettier": "3.8.4",
		"prettier-plugin-astro": "0.14.1",
		"typescript": "6.0.3",
		"unified": "11.0.5",
		"unist-util-visit": "5.1.0",
		"vite": "8.1.0"
	}
}
