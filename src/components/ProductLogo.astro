---
import Logo from "@components/svgs/Logo.svg";
---

<div class="product-logo">
	<Logo />
	<span>hood network</span>
</div>

<style>
	.product-logo {
		display: flex;
		align-items: center;
		gap: var(--hn-sys-shape-small);
		user-select: none;
	}

	.product-logo > svg {
		height: 1em;
		fill: var(--hn-ref-palette-brand);
	}

	.product-logo > svg:hover {
		animation: spin var(--hn-sys-motion-duration-extra-long4) infinite;
	}

	@keyframes spin {
		0% {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(1turn);
		}
	}

	.product-logo > span {
		line-height: var(--hn-sys-typescale-display-line-height);
		font-family: var(--hn-sys-typescale-display-font);
	}
</style>
