{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"paths": {
			"@components/*": ["./src/components/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@lib/*": ["./src/lib/*"],
			"@styles/*": ["./src/styles/*"],
			"@members": ["./members.ts"]
		}
	},
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"]
}
